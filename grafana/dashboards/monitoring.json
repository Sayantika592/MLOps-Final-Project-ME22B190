{
  "dashboard": {
    "id": null,
    "title": "Fake News Detection - Monitoring Dashboard",
    "tags": ["mlops", "fake-news"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Total Predictions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "prediction_requests_total",
            "legendFormat": "Total Predictions"
          }
        ]
      },
      {
        "title": "Prediction Latency (p95)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 Latency"
          }
        ]
      },
      {
        "title": "Predictions by Class",
        "type": "piechart",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "prediction_class_total",
            "legendFormat": "{{class}}"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(prediction_errors_total[5m]) / rate(prediction_requests_total[5m])",
            "legendFormat": "Error Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.05, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "title": "Input Text Length Distribution",
        "type": "histogram",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "input_text_length_bucket",
            "legendFormat": "Text Length"
          }
        ]
      },
      {
        "title": "Data Drift Score",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 10 },
        "targets": [
          {
            "expr": "data_drift_score",
            "legendFormat": "Drift Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.1, "color": "yellow" },
                { "value": 0.3, "color": "red" }
              ]
            }
          }
        }
      }
    ],
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" }
  }
}
